# ==================== 匿名情绪树洞 - 环境变量配置 ====================
# 复制此文件为 .env 并填写实际值

# 服务器配置
PORT=3000
NODE_ENV=development

# 数据库配置（SQLite - 开发环境）
DB_PATH=./data/treehouse.db

# 安全配置
SESSION_SECRET=your-session-secret-here-change-in-production
CORS_ORIGIN=http://localhost:3000,https://your-vercel-app.vercel.app

# 应用配置
SITE_NAME=匿名情绪树洞
SITE_SLOGAN=让心事有处安放，让温暖触手可及
MAX_MESSAGES_PER_DAY=10
DEFAULT_REPLY_TIME_HOURS=24

# 部署提示
# 生产环境请使用：
# NODE_ENV=production
# CORS_ORIGIN=https://your-production-domain.com
# 考虑使用PostgreSQL替代SQLite